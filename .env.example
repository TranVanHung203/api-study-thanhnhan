# Hướng dẫn lấy App Password cho Gmail:
# 1. Truy cập: https://myaccount.google.com/security
# 2. Bật xác thực 2 bước (2-Step Verification)
# 3. Tìm "App passwords" và tạo mật khẩu ứng dụng mới
# 4. Chọn "Mail" và thiết bị của bạn
# 5. Copy mật khẩu 16 ký tự và dán vào EMAIL_PASSWORD

# Nếu dùng Outlook/Hotmail:
# EMAIL_SERVICE=hotmail
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASSWORD=your-password

# Overwrite backup job (5:15 PM every day)
DB_BACKUP_SOURCE_DB=learning_app_29_01_2026
DB_BACKUP_TARGET_DB=learning_app
DB_BACKUP_CRON=15 17 * * *
DB_BACKUP_TIMEZONE=Asia/Ho_Chi_Minh
DB_BACKUP_BATCH_SIZE=1000
DB_BACKUP_PROTECTED_DBS=learning_app_29_01_2026

# Chatbot (Gemini ingest + DB search)
# Reuse MONGO_URI by default; this dbName controls chatbot storage.
CHATBOT_DB_NAME=chatbot_thanhnhan
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TEXT_TIMEOUT_MS=180000
GEMINI_TEXT_MAX_OUTPUT_TOKENS=8192
CHATBOT_MAX_TEXT_CHARS=90000
CHATBOT_MAX_ENTRIES_PER_FILE=180
CHATBOT_SEARCH_LIMIT=30
CHATBOT_MIN_MATCH_SCORE=1.4
CHATBOT_MIN_SCORE_GAP=0.55
CHATBOT_USE_ATLAS_SEARCH=true
CHATBOT_ATLAS_SEARCH_INDEX=chatbot_knowledge_index

# OAuth social login
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
FACEBOOK_APP_ID=<YOUR_FACEBOOK_APP_ID>
FACEBOOK_APP_SECRET=<YOUR_FACEBOOK_APP_SECRET>
ZALO_APP_ID=<YOUR_ZALO_APP_ID>
ZALO_APP_SECRET=<YOUR_ZALO_APP_SECRET>
ZALO_REDIRECT_URI=https://your-domain.com/zalo-callback
ZALO_CALLBACK_SCHEME=easymathzalo
ZALO_CALLBACK_PATH=zalo-callback
# Optional: if set, this value is used directly instead of scheme/path above
ZALO_MOBILE_DEEP_LINK=easymathzalo://zalo-callback
# Optional: web callback destination (Flutter web). If empty, backend falls back to /zalo-test.
ZALO_WEB_REDIRECT_URL=https://your-web-domain.com/zalo-callback
# Optional: auto | web | mobile (auto detects from platform/state/user-agent)
ZALO_CALLBACK_DEFAULT_TARGET=auto
